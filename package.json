{
  "name": "app",
  "version": "0.1.19",
  "scripts": {
    "start": "pnpm run stop_appserver_ports && ng serve",
    "start_emulators": "pnpm run emulators_stop && firebase emulators:start --import=./emulators.backup --export-on-exit=./emulators.backup",
    "start_functions": "pnpm --dir functions run start",
    "start_ios": "ionic cap run ios -l --external --open -- --hmr",
    "start_android": "ionic cap run android -l --external --open --disable-host-check -- --hmr",
    "start_wifi": "ionic serve --external -- --hmr",
    "deploy_apps": "pnpm run build && pnpm run update_apps && ./build/android/build.sh && ./build/ios/build.sh",
    "update_apps": "pnpm dlx trapeze run config-trapeze.yaml --android-project android --ios-project ios/App -y",
    "build": "ng build --configuration production",
    "build_ionic": "ionic cap sync --deployment --configuration production",
    "build_android": "pnpm run build && ./build/android/build.sh",
    "build_deploy_ios": "pnpm run build && ./build/ios/build.sh",
    "deploy_hosting-alpha": "pnpm run build && firebase hosting:channel:deploy alpha",
    "deploy_website": "pnpm run build && firebase deploy --only hosting,firestore:rules,database:rules",
    "deploy_functions": "firebase use prod && firebase deploy --only functions",
    "deploy_rules": "firebase deploy --only firestore:rules,database:rules",
    "deploy_indexes": "firebase deploy --only firestore:indexes",
    "deploy": "firebase deploy",
    "downsync_indexes": "firebase firestore:indexes > firestore.indexes.json",
    "cap_sync": "ionic cap sync",
    "cap_update": "ionic cap update",
    "emulators_setup": "bash ./_emulator-setup.sh",
    "emulators_stop": "kill-port 4000 4001 9099 5001 8080 9000 5002 8085",
    "stop_appserver_ports": "kill-port 8100 4200",
    "ng": "ng",
    "watch": "ng build --watch --configuration development",
    "test": "jest --config jest.config.js --passWithNoTests",
    "test:watch": "jest --config jest.config.js --watch --passWithNoTests",
    "lint": "eslint .",
    "lint_fix": "eslint . --fix",
    "prettify": "prettier --write \"src/**/*.{ts,html}\"",
    "bump-patch-version": "pnpm version patch -m \"+v%s [patch] [skip ci]\"",
    "bump-minor-version": "pnpm version patch -m \"+v%s [minor] [skip ci]\"",
    "preset-version": "git fetch --prune --prune-tags",
    "postset-version": "git push --tags",
    "ci:push": "git push orgin",
    "ci:set-version": "pnpm version --no-git-tag-version",
    "set-version": "pnpm version",
    "cordova:resources": "cordova-res --skip-config --copy",
    "create_pwa_assets": "node utils/pwa-asset-generator.mjs && prettier \"src/index.html\" --write",
    "analyze": "webpack-bundle-analyzer dist/stats.json",
    "e2e": "ng e2e",
    "install-all": "pnpm install -r"
  },
  "engines": {
    "node": "^20.19.0 || ^22.12.0 || ^24.0.0"
  },
  "prettier": {
    "printWidth": 120,
    "singleQuote": true,
    "endOfLine": "lf",
    "tabWidth": 2,
    "trailingComma": "es5",
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/cdk": "^20.2.14",
    "@angular/common": "^20.3.18",
    "@angular/compiler": "^20.3.18",
    "@angular/core": "^20.3.18",
    "@angular/fire": "^20.0.1",
    "@angular/forms": "^20.3.18",
    "@angular/material": "^20.2.14",
    "@angular/material-luxon-adapter": "^20.2.14",
    "@angular/platform-browser": "^20.3.18",
    "@angular/platform-server": "^20.3.18",
    "@angular/router": "^20.3.18",
    "@angular/ssr": "^20.3.20",
    "@capacitor/camera": "^8.0.2",
    "@capacitor/core": "^8.2.0",
    "@capacitor/local-notifications": "^8.0.2",
    "@capacitor/push-notifications": "^8.0.2",
    "@capacitor/share": "^8.0.1",
    "@faker-js/faker": "^10.0.0",
    "@ionic/pwa-elements": "^3.4.0",
    "@ngx-formly/core": "^7.1.0",
    "@ngx-formly/material": "^7.1.0",
    "@tailwindcss/typography": "^0.5.19",
    "firebase": "^11.10.0",
    "lightweight-charts": "^5.0.9",
    "luxon": "^3.7.1",
    "ngx-pipes": "^3.2.2",
    "ngx-quill": "^28.0.1",
    "quill": "^2.0.3",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular/build": "^20.3.22",
    "@angular/cli": "^20.3.22",
    "@angular/compiler-cli": "^20.3.18",
    "@angular/platform-browser-dynamic": "^20.3.18",
    "@eslint/js": "^10.0.1",
    "@jest/globals": "^30.3.0",
    "@tailwindcss/postcss": "^4.1.13",
    "@types/jest": "^30.0.0",
    "@types/luxon": "^3.7.1",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "jest-preset-angular": "^16.1.4",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.1",
    "ts-jest": "^29.4.9",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.56.1"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
